      "targets": [{ "expr": "up{job=\"clickhouse\"}", "refId": "A" }],
      "title": "ClickHouse: доступность",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
